{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const fs=require('node:fs');const path=require('node:path');const {spawn}=require('node:child_process');const root=process.env.CLAUDE_COMPANION_PLUGIN_ROOT||process.cwd();const script=path.resolve(root,'hooks','claude-stop-review.mjs');if(!fs.existsSync(script)){process.exit(0)}const child=spawn(process.execPath,[script],{stdio:'inherit'});child.on('exit',(code,signal)=>{if(signal){process.kill(process.pid,signal)}else{process.exit(code??1)}});child.on('error',(error)=>{console.error(error.message);process.exit(0)});\"",
            "timeout": 120,
            "statusMessage": "Checking optional Claude Stop review"
          }
        ]
      }
    ]
  }
}
